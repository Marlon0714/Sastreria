# Supabase configuration
# Copy this file as .env and fill in your real values.
# NEVER commit .env with real credentials.
#
# Find these values in your Supabase project:
#   Settings > API > Project URL and Project API keys (anon/public)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
