{
  "name": "sastreria",
  "version": "0.1.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "dev": "ANDROID_HOME=/home/developer/Android/Sdk ANDROID_SDK_ROOT=/home/developer/Android/Sdk PATH=$PATH:/home/developer/Android/Sdk/platform-tools:/home/developer/Android/Sdk/emulator expo start",
    "dev:android": "ANDROID_HOME=/home/developer/Android/Sdk ANDROID_SDK_ROOT=/home/developer/Android/Sdk PATH=$PATH:/home/developer/Android/Sdk/platform-tools:/home/developer/Android/Sdk/emulator expo start --android",
    "dev:web": "expo start --web",
    "emulator": "bash scripts/start-emulator.sh",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "apk:debug": "cd android && ./gradlew assembleDebug",
    "apk:release": "cd android && ./gradlew assembleRelease",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --passWithNoTests --watchAll=false",
    "lint": "expo lint",
    "validate": "npm run typecheck && npm run test:ci",
    "validate:full": "npm run typecheck && npm run lint && npm run test:ci",
    "commit": "bash scripts/smart-commit.sh",
    "branch": "bash scripts/smart-branch.sh"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "src/__tests__/factories/"
    ],
    "collectCoverageFrom": [
      "src/features/**/*.{ts,tsx}",
      "src/data/**/*.{ts,tsx}",
      "src/shared/**/*.{ts,tsx}",
      "!**/__tests__/**",
      "!**/*.test.{ts,tsx}"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 70,
        "functions": 70,
        "branches": 70
      }
    }
  },
  "dependencies": {
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.12",
    "expo": "~54.0.33",
    "expo-crypto": "~15.0.9",
    "expo-notifications": "^0.32.17",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.74.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.1.0",
    "eas-cli": "^18.8.1",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
